# Force LF line endings for scripts/configs qui seront exécutés côté Linux (VPS).
# Évite les "bad interpreter: /usr/bin/env\r" quand on clone depuis un Windows.

* text=auto eol=lf

# Scripts shell : impérativement LF
*.sh text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Configs Docker / CI
*.yml text eol=lf
*.yaml text eol=lf

# Sources
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binaires — pas de conversion
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.pdf binary
