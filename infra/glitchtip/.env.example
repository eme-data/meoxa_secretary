# Variables d'env pour la stack GlitchTip (copier en .env puis remplir)

# Secret Django — générer avec : openssl rand -hex 50
GLITCHTIP_SECRET_KEY=

# Mot de passe Postgres (libre)
GLITCHTIP_DB_PASSWORD=

# Domaine public si reverse proxy HTTPS (sinon laisse http://IP:8001)
GLITCHTIP_DOMAIN=https://errors.meoxa.app
GLITCHTIP_FROM_EMAIL=noreply@meoxa.app

# Email delivery (optionnel) — pour reset password / notif :
#   smtp://user:pass@host:587?tls=True
#   ou consolemail:// pour afficher dans les logs (par défaut)
GLITCHTIP_EMAIL_URL=consolemail://
