# ------------------------------------------------------------------
# meoxa_secretary — variables d'environnement
# Copier ce fichier en `.env` pour le développement local,
# ou `.env.prod` sur le VPS de production.
# ------------------------------------------------------------------

# --- Général ---
ENVIRONMENT=development            # development | production
APP_NAME=meoxa_secretary
# En production : APP_DOMAIN=secretary.meoxa.app
APP_DOMAIN=localhost
LOG_LEVEL=INFO

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# En production : BACKEND_URL=https://secretary.meoxa.app
BACKEND_URL=http://localhost:8000
# Secret utilisé pour signer les JWT. Générer avec: `openssl rand -hex 32`
JWT_SECRET=change-me-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
CORS_ORIGINS=http://localhost:3000
# Clé Fernet pour chiffrer les secrets stockés en base (API keys, client secrets…).
# Générer avec: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
SETTINGS_ENCRYPTION_KEY=change-me-fernet-key

# --- Frontend ---
# En production : FRONTEND_URL=https://secretary.meoxa.app
#                 NEXT_PUBLIC_API_URL=https://secretary.meoxa.app
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- PostgreSQL ---
POSTGRES_USER=meoxa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=meoxa_secretary
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://meoxa:change-me@postgres:5432/meoxa_secretary

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ------------------------------------------------------------------
# ⚠️ Les variables ci-dessous (Microsoft 365, Anthropic, Bot Teams, S3)
# sont configurables depuis l'interface super-admin — pas besoin de
# les mettre ici en prod. Elles servent uniquement de fallback dev
# si la table `platform_settings` est vide.
# ------------------------------------------------------------------

# --- Microsoft 365 (Azure AD app multi-tenant, partagée entre tous les clients) ---
# En production : MS_REDIRECT_URI=https://secretary.meoxa.app/api/v1/integrations/microsoft/callback
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/microsoft/callback
MS_GRAPH_SCOPES=User.Read Mail.ReadWrite Calendars.ReadWrite OnlineMeetings.ReadWrite Files.Read.All Tasks.ReadWrite

# --- Teams bot (Bot Framework) ---
BOT_APP_ID=
BOT_APP_PASSWORD=
BOT_TENANT_ID=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_ADVANCED=claude-opus-4-7

# --- Stockage objets (optionnel, S3-compatible pour enregistrements audio/CR) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# --- Observabilité (GlitchTip / Sentry) ---
# DSN fourni par GlitchTip après création du projet. Vide = pas d'envoi.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (exposé au navigateur) — peut être identique ou différent (2 projets)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
# Upload des source maps lors du build Next.js (facultatif)
SENTRY_URL=https://errors.meoxa.app
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- SEO & analytics ---
# URL racine du site vitrine (utilisée dans sitemap.xml, robots.txt, OG image).
NEXT_PUBLIC_SITE_URL=https://secretary.meoxa.app
# Activer Plausible Analytics (RGPD-friendly, pas de bandeau cookie requis).
# Vide = pas d'analytics. Exemple : NEXT_PUBLIC_PLAUSIBLE_DOMAIN=secretary.meoxa.app
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Pour pointer vers Plausible Cloud par défaut, laisser vide. Pour self-hosted,
# mettre l'URL du script, ex: https://analytics.meoxa.app/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SRC=

# --- Backup off-site (production uniquement) ---
# Configurer un remote rclone sur le VPS (`rclone config`), puis renseigner ici.
# Exemple: RCLONE_REMOTE="b2:meoxa-backups/prod"
RCLONE_REMOTE=
BACKUP_DIR=/var/backups/meoxa
RETENTION_DAYS=14
